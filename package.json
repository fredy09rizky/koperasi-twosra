{
	"name": "koperasi-twosra-backend",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"smoke": "node scripts/smoke-test.mjs",
		"smoke:gateway": "node scripts/smoke-test.mjs --with-gateway",
