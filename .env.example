# Production Environment Variables
# ===========================================
# File ini BUKAN untuk development lokal.
# Untuk development lokal, pakai .dev.vars (copy dari .dev.vars.example).
#
# File ini hanya referensi saat deploy production.
# Isi setiap secret via CLI:
#   npx wrangler secret put <KEY>
# ===========================================

# === WAJIB DIISI ===

# JWT admin — minimal 32 karakter
JWT_SECRET=

# Pakasir payment gateway
PAKASIR_PROJECT_SLUG=
PAKASIR_API_KEY=

# Telegram bot & log routing
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ORDER=
TELEGRAM_TOPIC_SECURITY=
TELEGRAM_TOPIC_ADMIN=

# Environment untuk structured logging dan startup validation.
# Wajib bernilai development atau production; set ke production saat deploy.
ENVIRONMENT=

# === OPSIONAL (boleh kosong) ===

# CORS — origin tambahan selain origin Worker (boleh kosong)
# Contoh: https://domain-a.com,https://domain-b.com
CORS_ALLOWED_ORIGINS=

# Image optimization — allowlist domain sumber gambar eksternal
# Boleh kosong; default: images.pexels.com,i.ibb.co
# Bisa diubah sesuai kebutuhan, misalnya: images.pexels.com,i.ibb.co,*.unsplash.com
IMAGE_OPTIMIZE_ALLOWED_DOMAINS=

# Shared key untuk request mutating non-browser (mis. webhook internal) tanpa Origin/Referer.
# Kirim sebagai header: x-internal-key
INTERNAL_WEBHOOK_KEY=
